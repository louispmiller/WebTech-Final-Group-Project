<!-- PHPUnit configuration for the backend architecture test suite -->
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true">

    <testsuites>
        <testsuite name="Backend Architecture Tests">
            <directory>tests/</directory>
        </testsuite>
    </testsuites>

    <source>
        <include>
            <directory>core/</directory>
            <directory>backend/models/</directory>
            <directory>backend/services/</directory>
        </include>
    </source>

</phpunit>