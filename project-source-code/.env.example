# Database connection (used by app/Core/Database.php)
DB_DRIVER=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=smart_city_dashboard
DB_USER=root
DB_PASS=

# External APIs used by the City Search & Registration module
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
# Nominatim's usage policy requires a descriptive User-Agent identifying the app/contact
HTTP_USER_AGENT="SmartCityDashboard/1.0 (contact: sidimedebnououmar@gmail.com)"

# REST Countries v3.1 (the version in the original project instructions) has been
# discontinued by the provider. v5 replaces it and requires a free API key:
# 1. Sign up at https://restcountries.com/sign-up
# 2. Create an API key from your dashboard
# 3. Paste it below (never commit a real key here - this file is tracked by git,
#    put your real key in .env instead, which is gitignored)
# Without a key, city registration still works fully - only the optional
# "region"/population enrichment is omitted (see CountryService::resolveRegion).
RESTCOUNTRIES_BASE_URL=https://api.restcountries.com/countries/v5
RESTCOUNTRIES_API_KEY=
